// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  WORKER
  CLIENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum TicketStatus {
  BACKLOG
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
  WAITING
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Hashed password
  role          UserRole  @default(WORKER)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  ownedProjects    Project[]        @relation("ProjectOwner")
  projectMembers   ProjectMember[]
  assignedTickets  Ticket[]         @relation("AssignedTickets")
  createdTickets   Ticket[]         @relation("CreatedTickets")
  comments         Comment[]
  sentInvites      Invite[]         @relation("SentInvites")
  
  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  startDate   DateTime
  endDate     DateTime?
  status      ProjectStatus @default(ACTIVE)
  
  // JSON fields
  columns     Json          // Array de colunas: [{ id, title, order }]
  settings    Json          // { requireEstimateBeforeStart, estimateRequired }
  
  // Relations
  ownerId     String
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  members     ProjectMember[]
  tickets     Ticket[]
  invites     Invite[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role      UserRole
  
  createdAt DateTime @default(now())
  
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Ticket {
  id             String        @id @default(cuid())
  title          String
  description    String?       @db.Text
  status         TicketStatus  @default(BACKLOG)
  
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assignedToId   String?
  assignedTo     User?         @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  createdById    String
  createdBy      User          @relation("CreatedTickets", fields: [createdById], references: [id], onDelete: Cascade)
  
  estimatedHours Float?
  loggedHours    Float         @default(0)
  
  // JSON fields
  approvals      Json          // { owner: boolean?, client: boolean? }
  lifecycleLog   Json          // Array: [{ from, to, by, at }]
  
  // Relations
  comments       Comment[]
  attachments    Attachment[]
  
  // Position in column (for ordering)
  position       Int           @default(0)
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
  @@map("tickets")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([ticketId])
  @@index([userId])
  @@map("comments")
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int?
  type      String?
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([ticketId])
  @@map("attachments")
}

model Invite {
  id          String       @id @default(cuid())
  email       String
  token       String       @unique
  role        UserRole
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  invitedById String
  invitedBy   User         @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@unique([projectId, email])
  @@index([token])
  @@index([email])
  @@map("invites")
}
