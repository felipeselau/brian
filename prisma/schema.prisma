// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  WORKER
  CLIENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum TicketStatus {
  BACKLOG
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
  WAITING
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Hashed password
  role          UserRole  @default(WORKER)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  ownedProjects    Project[]        @relation("ProjectOwner")
  projectMembers   ProjectMember[]
  assignedTickets  Ticket[]         @relation("AssignedTickets")
  createdTickets   Ticket[]         @relation("CreatedTickets")
  comments         Comment[]
  sentInvites      Invite[]         @relation("SentInvites")
  reactions        Reaction[]
  
  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  startDate   DateTime
  endDate     DateTime?
  status      ProjectStatus @default(ACTIVE)
  
  // JSON fields
  columns     Json          // Array de colunas: [{ id, title, order }]
  settings    Json          // { requireEstimateBeforeStart, estimateRequired }
  
  // Relations
  ownerId     String
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  members     ProjectMember[]
  tickets     Ticket[]
  invites     Invite[]
  labels      Label[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id               String   @id @default(cuid())
  
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role             UserRole
  
  canCreateTickets Boolean  @default(false)
  
  createdAt        DateTime @default(now())
  
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Ticket {
  id             String        @id @default(cuid())
  title          String
  description    String?       @db.Text
  status         TicketStatus  @default(BACKLOG)
  
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assignedToId   String?
  assignedTo     User?         @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  createdById    String
  createdBy      User          @relation("CreatedTickets", fields: [createdById], references: [id], onDelete: Cascade)
  
  estimatedHours Float?
  loggedHours    Float         @default(0)
  
  isClientRequest Boolean      @default(false)
  
  // Due date
  dueDate        DateTime?
  
  // Cover image URL
  coverImage     String?
  
  // JSON fields
  approvals      Json          // { owner: boolean?, client: boolean? }
  lifecycleLog   Json          // Array: [{ from, to, by, at }]
  
  // Relations
  comments       Comment[]
  attachments    Attachment[]
  ticketLabels   TicketLabel[]
  checklists     Checklist[]
  
  // Position in column (for ordering)
  position       Int           @default(0)
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
  @@map("tickets")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  reactions  Reaction[]
  
  // Mentions: array of user IDs mentioned in this comment
  mentions  Json?   // e.g. ["userId1", "userId2"]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([ticketId])
  @@index([userId])
  @@map("comments")
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int?
  type      String?
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([ticketId])
  @@map("attachments")
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   // hex color e.g. "#ff5733"
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  tickets   TicketLabel[]
  
  createdAt DateTime @default(now())
  
  @@index([projectId])
  @@map("labels")
}

model TicketLabel {
  ticketId String
  labelId  String
  
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  label    Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)
  
  @@id([ticketId, labelId])
  @@index([ticketId])
  @@index([labelId])
  @@map("ticket_labels")
}

model Checklist {
  id        String          @id @default(cuid())
  title     String
  
  ticketId  String
  ticket    Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  items     ChecklistItem[]
  position  Int             @default(0)
  
  createdAt DateTime        @default(now())
  
  @@index([ticketId])
  @@map("checklists")
}

model ChecklistItem {
  id          String    @id @default(cuid())
  content     String
  completed   Boolean   @default(false)
  
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  
  position    Int       @default(0)
  
  createdAt   DateTime  @default(now())
  
  @@index([checklistId])
  @@map("checklist_items")
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String   // e.g. "👍", "❤️"
  
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([commentId, userId, emoji])
  @@index([commentId])
  @@index([userId])
  @@map("reactions")
}

model Invite {
  id          String       @id @default(cuid())
  email       String
  token       String       @unique
  role        UserRole
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  invitedById String
  invitedBy   User         @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@unique([projectId, email])
  @@index([token])
  @@index([email])
  @@map("invites")
}
